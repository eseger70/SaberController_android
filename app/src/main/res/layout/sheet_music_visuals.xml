<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/assign_visual_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="@color/app_text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/track_visual_policy_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="@color/app_text_secondary" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleTrackPolicy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPolicyAuto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/track_policy_auto"
                android:textColor="@color/app_text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPolicySaber"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/track_policy_preserve"
                android:textColor="@color/app_text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPolicyMusic"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/track_policy_visual"
                android:textColor="@color/app_text_primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/visual_target_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="@color/app_text_secondary" />

        <TextView
            android:id="@+id/textVisualTargetValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_chip_neutral"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/visual_target_none"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/app_header_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/track_visual_selected_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="@color/app_text_secondary" />

        <Spinner
            android:id="@+id/spinnerTrackVisuals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_chip_neutral"
            android:popupBackground="@drawable/bg_spinner_popup" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonApplyTrackVisual"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/apply_short"
                android:textColor="@color/app_text_primary"
                app:backgroundTint="@color/app_surface_alt" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClearTrackVisual"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/clear_visual"
                android:textColor="@color/app_text_primary"
                app:backgroundTint="@color/app_surface_alt" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPreviewTrackVisual"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/preview_short"
                android:textColor="@color/app_text_primary"
                app:backgroundTint="@color/app_surface_alt"
                app:icon="@android:drawable/ic_menu_view"
                app:iconTint="@color/app_text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonStopTrackVisualPreview"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/stop_preview_short"
                android:textColor="@color/app_text_primary"
                app:backgroundTint="@color/app_surface_alt" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAssignTrackVisual"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/assign_to_selection"
                android:textColor="@color/app_on_primary"
                app:backgroundTint="@color/app_primary"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_control_effects"
                app:iconTint="@color/app_on_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClearVisualAssignment"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/clear_selection_assignment"
                android:textColor="@color/app_text_primary"
                app:backgroundTint="@color/app_surface_alt" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAssignDefaultVisual"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/set_default_visual"
                android:textColor="@color/app_text_primary"
                app:backgroundTint="@color/app_surface_alt" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClearDefaultVisual"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/clear_default_visual"
                android:textColor="@color/app_text_primary"
                app:backgroundTint="@color/app_surface_alt" />
        </LinearLayout>

        <TextView
            android:id="@+id/textVisualAssignmentSummaryValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_chip_neutral"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/visual_assignment_default_summary"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/app_header_text" />
    </LinearLayout>
</ScrollView>
