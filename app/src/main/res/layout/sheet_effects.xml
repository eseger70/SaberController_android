<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/app_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/effects_sheet_title"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:textColor="@color/app_text_primary" />

    <TextView
        android:id="@+id/textEffectsStatusValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_chip_neutral"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:text="@string/state_unknown"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="@color/app_header_text" />

    <TextView
        android:id="@+id/textEffectsContextValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_value_panel"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp"
        android:text="@string/effects_context_placeholder"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="@color/app_text_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/instant_effects_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
        android:textColor="@color/app_text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClash"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/effect_clash"
            android:textColor="@color/app_text_primary"
            app:backgroundTint="@color/app_surface_alt" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStab"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/effect_stab"
            android:textColor="@color/app_text_primary"
            app:backgroundTint="@color/app_surface_alt" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonForce"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/effect_force"
            android:textColor="@color/app_text_primary"
            app:backgroundTint="@color/app_surface_alt" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBlast"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/effect_blast"
            android:textColor="@color/app_text_primary"
            app:backgroundTint="@color/app_surface_alt" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/sustained_effects_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
        android:textColor="@color/app_text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLockup"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/effect_lockup"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/app_outline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDrag"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/effect_drag"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/app_outline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLightningBlock"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/effect_lightning_block"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/app_outline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMelt"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/effect_melt"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/app_outline" />
    </LinearLayout>

</LinearLayout>
