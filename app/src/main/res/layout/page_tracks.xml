<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/app_surface_alt"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/textNowPlayingValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_value_panel"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:text="@string/state_none"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/app_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textElapsedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_zero"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@color/app_text_secondary" />

                <ProgressBar
                    android:id="@+id/progressTrack"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:max="1000"
                    android:progress="0"
                    android:progressBackgroundTint="@color/app_surface"
                    android:progressTint="@color/app_primary" />

                <TextView
                    android:id="@+id/textRemainingValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/time_zero"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@color/app_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonPreviousTrack"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/previous_track"
                    app:backgroundTint="@color/app_surface"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_media_previous"
                    app:iconTint="@color/app_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonTogglePauseTrack"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/play_pause_track"
                    app:backgroundTint="@color/app_primary"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_control_play"
                    app:iconTint="@color/app_on_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonNextTrack"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/next_track"
                    app:backgroundTint="@color/app_surface"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_media_next"
                    app:iconTint="@color/app_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonStopTrack"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/stop_track"
                    app:backgroundTint="@color/app_surface"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_control_stop"
                    app:iconTint="@color/app_off_color" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonShuffleQueue"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/shuffle"
                    app:backgroundTint="@color/app_surface"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_control_shuffle"
                    app:iconTint="@color/app_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonRepeatQueue"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/repeat"
                    app:backgroundTint="@color/app_surface"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_control_repeat"
                    app:iconTint="@color/app_primary" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/app_surface"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textTrackListLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/music_library_title"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    android:textColor="@color/app_text_primary" />

                <TextView
                    android:id="@+id/textTrackCountValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_neutral"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="@string/track_count_empty"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@color/app_header_text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonRefreshTracks"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:minWidth="0dp"
                    android:text="@string/refresh_short"
                    android:textColor="@color/app_text_primary"
                    app:backgroundTint="@color/app_surface_alt"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_popup_sync"
                    app:iconTint="@color/app_text_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/textSelectedTrackGroupValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip_neutral"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="@string/music_scope_none"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="@color/app_header_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonPlayTrackGroup"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="@string/play_track_group"
                    android:textColor="@color/app_on_primary"
                    app:backgroundTint="@color/app_primary"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_control_play"
                    app:iconTint="@color/app_on_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonOpenMusicVisuals"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/assign_visual"
                    android:textColor="@color/app_text_primary"
                    app:backgroundTint="@color/app_surface_alt"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_control_effects"
                    app:iconTint="@color/app_text_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonExpandAllTracks"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/expand_all_tracks"
                    android:textColor="@color/app_text_primary"
                    app:backgroundTint="@color/app_surface_alt" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCollapseAllTracks"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/collapse_all_tracks"
                    android:textColor="@color/app_text_primary"
                    app:backgroundTint="@color/app_surface_alt" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volume_label"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/textMusicVolumeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:minWidth="36dp"
                    android:text="@string/volume_unknown"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/app_primary" />

                <SeekBar
                    android:id="@+id/seekMusicVolume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:max="2000"
                    android:progressTint="@color/app_primary"
                    android:thumbTint="@color/app_primary" />
            </LinearLayout>

            <ListView
                android:id="@+id/listTracks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:listSelector="@android:color/transparent"
                android:scrollbarStyle="outsideInset" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
