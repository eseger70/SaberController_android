<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textSaberStatusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/saber_status_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <TextView
        android:id="@+id/textSaberStatusValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/state_unknown"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonOn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/on" />

        <Button
            android:id="@+id/buttonOff"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/off" />

        <Button
            android:id="@+id/buttonSyncSaber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/sync_saber" />
    </LinearLayout>

    <TextView
        android:id="@+id/textLastStateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/saber_state_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <TextView
        android:id="@+id/textLastStateValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/state_unknown"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <TextView
        android:id="@+id/textCurrentPresetLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/current_preset_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <TextView
        android:id="@+id/textCurrentPresetValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/state_unknown"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <TextView
        android:id="@+id/textPresetCountValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/preset_count_empty"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

    <ListView
        android:id="@+id/listPresets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:dividerHeight="1dp" />

    <TextView
        android:id="@+id/textVolumeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/volume_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/volume_unknown"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <Button
            android:id="@+id/buttonRefreshVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/refresh_volume" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="3000" />

</LinearLayout>
