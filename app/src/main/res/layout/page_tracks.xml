<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textTrackStatusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/track_status_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <TextView
        android:id="@+id/textTrackStatusValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/state_unknown"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <TextView
        android:id="@+id/textNowPlayingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/now_playing_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <TextView
        android:id="@+id/textNowPlayingValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/state_none"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonRefreshTracks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/refresh_tracks" />

        <Button
            android:id="@+id/buttonRefreshNowPlaying"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/refresh_now_playing" />

        <Button
            android:id="@+id/buttonStopTrack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/stop_track" />
    </LinearLayout>

    <TextView
        android:id="@+id/textTrackListLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/track_list_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <TextView
        android:id="@+id/textTrackCountValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/track_count_empty"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

    <ListView
        android:id="@+id/listTracks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:dividerHeight="1dp" />

    <TextView
        android:id="@+id/textVolumeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/volume_label"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/volume_unknown"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <Button
            android:id="@+id/buttonRefreshVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/refresh_volume" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="3000" />

</LinearLayout>
