<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/app_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_label"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/app_text_primary" />

            <TextView
                android:id="@+id/textLogHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/log_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/app_text_secondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCopyLog"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/copy_log"
                    android:textColor="@color/app_text_primary"
                    app:backgroundTint="@color/app_surface_alt"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCopyLastFrame"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/copy_last_frame"
                    android:textColor="@color/app_text_primary"
                    app:backgroundTint="@color/app_surface_alt"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/raw_command_label"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textColor="@color/app_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/raw_command_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/app_text_secondary" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/raw_command_field_hint"
                app:boxBackgroundColor="@color/app_surface_alt"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputRawCommand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:imeOptions="actionSend"
                    android:inputType="textNoSuggestions|textVisiblePassword"
                    android:maxLines="1"
                    android:textColor="@color/app_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/checkAwaitResponse"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/await_response"
                    android:textColor="@color/app_text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSendRawCommand"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/send_command"
                    android:textColor="@color/app_on_primary"
                    app:backgroundTint="@color/app_primary"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/app_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp">

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_log_panel"
            android:fillViewport="true">

            <TextView
                android:id="@+id/textLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:longClickable="true"
                android:padding="14dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/app_log_text"
                android:textIsSelectable="true" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
